// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  // TODO: Organize
  "which_key": {
    "enabled": true,
  },
  "session": {
    "trust_all_worktrees": false,
  },
  "cli_default_open_behavior": "new_window",
  "language_models": {
    "ollama": {
      "context_window": 4096,
      "api_url": "http://127.0.0.1:11434",
    },
  },
  "minimum_split_diff_width": 120.0,
  "buffer_font_family": "Monaspace Neon",
  "horizontal_scroll_margin": 6.0,
  "fast_scroll_sensitivity": 10.0,
  "autoscroll_on_clicks": false,
  "scrollbar": {
    "diagnostics": "all",
  },
  "inline_code_actions": false,
  "drag_and_drop_selection": {
    "enabled": false,
  },
  "diff_view_style": "split",
  "format_on_save": "off",
  "remove_trailing_whitespace_on_save": false,
  "languages": {
    "Rust": {
      "document_folding_ranges": "on",
      "indent_guides": {
        "background_coloring": "disabled",
      },
      "inlay_hints": {
        "enabled": true,
      },
    },
    "C++": {
      "inlay_hints": {
        "enabled": true,
      },
    },
    "C": {
      "show_edit_predictions": false,
    },
    "Nix": {
      "tab_size": 2,
    },
    "Python": {
      "inlay_hints": {
        "show_type_hints": true,
        "show_value_hints": true,
        "show_background": false,
        "enabled": true,
      },
      "hard_tabs": false,
      "language_servers": ["pyrefly", "ruff"],
    },
  },
  "lsp": {
    "ruff": {
      "initialization_options": {
        "settings": {
          "lineLength": 120,
          "lint": {
            "select": ["ALL"],
            "ignore": [
              "INP001", // Allow implicit namespace package (don't make me make an __init__.py for everything)
              "T201", // Allow print statements
              "S101", // Allow asserts
              "EXE002", // Don't need shebangs for Python
              "FIX002", // Allow TODOs
              "TD002", // TODOs don't need author
              "TD003", // Or issue link
              "PLR0913", // Allow more parameters in functions
              "FBT001", // Allow booleans in functions
              "FBT002", // Allow booleans in functions
              "ERA001", // Allow commented out code
              "D401", // Disable imparative mood docstring check
              "TRY003", // Allow specifying long messages outside exception class
              "EM101", // Allow exceptions to use string literals
              "EM102", // Allow exceptions to use f-strings
              "G004", // Allow logging statements to use f-strings
            ],
          },
          // 	"select": ["D"], // Enable all pydocstyle rules
          // 	"ignore": ["D100"],
          // 	"pydocstyle": {
          // 		"convention": "google", // Strict doc conventions
          // 	},
          // },
        },
      },
    },
    "rust-analyzer": {
      "initialization_options": {
        "cargo": {
          "targetDir": true, // Use separate directory for r-a to avoid lock contention
        },
        "files": {
          "exclude": [".git", "target", ".direnv", ".venv"],
        },
        "check": {
          "command": "clippy",
          "extraArgs": ["--no-deps"],
        },
      },
    },
  },
  "show_edit_predictions": true,
  "agent_buffer_font_size": 12.0,
  "extend_comment_on_newline": false,
  "vertical_scroll_margin": 6.0,
  "file_finder": {
    "skip_focus_for_active_in_search": true,
    "file_icons": true,
  },
  "toolbar": {
    // // Hide toolbar
    // "breadcrumbs": false,
    // "quick_actions": false,
    "agent_review": true,
  },
  "disable_ai": false,
  "when_closing_with_no_tabs": "platform_default",
  "collaboration_panel": {
    "dock": "left",
    "button": false,
  },
  "debugger": {
    "dock": "bottom",
  },
  "git_panel": {
    "fallback_branch_name": "main",
    "button": false,
    "dock": "right",
    "show_count_badge": false,
    "scrollbar": {
      "show": "never",
    },
    "tree_view": true,
    "default_width": 240.0,
    "sort_by_path": false,
    "collapse_untracked_diff": false,
    "status_style": "label_color",
  },
  "outline_panel": {
    "dock": "right",
    "button": true,
  },
  "project_panel": {
    "auto_reveal_entries": true,
    "dock": "right",
    "git_status_indicator": true,
    "diagnostic_badges": true,
    "scrollbar": {
      "show": "never",
    },
    "button": false,
    "hide_gitignore": false,
    "sort_mode": "directories_first",
    "hide_hidden": false,
    "hide_root": true,
    "starts_open": true,
    "indent_size": 12.0,
    "git_status": true,
    "folder_icons": true,
    "entry_spacing": "standard",
  },
  "window_decorations": "client",
  "centered_layout": {
    "right_padding": 0.2,
  },
  "tab_bar": {
    "show": true,
    "show_nav_history_buttons": false,
    "show_tab_bar_buttons": true,
  },
  "tabs": {
    "show_diagnostics": "all",
    "file_icons": true,
    "git_status": true,
  },
  "title_bar": {
    "show_branch_name": true,
    "show_branch_status_icon": true,
    "button_layout": "platform_default",
    "show_menus": false,
  },
  "search": {
    "button": false,
  },
  "diagnostics": {
    "button": true,
    "inline": {
      "enabled": true,
    },
  },
  "sticky_scroll": {
    "enabled": true,
  },
  "indent_guides": {
    "coloring": "indent_aware",
    "background_coloring": "disabled",
  },
  "always_treat_brackets_as_autoclosed": true,
  "colorize_brackets": true,
  "minimap": {
    "current_line_highlight": "all",
    "thumb_border": "left_open",
    "thumb": "always",
    "show": "always",
  },
  "scroll_beyond_last_line": "vertical_scroll_margin",
  "agent_ui_font_size": 12.0,
  "hard_tabs": false,
  "buffer_line_height": {
    "custom": 1.45,
  },
  "git": {
    "hunk_style": "staged_hollow",
    "enable_diff": true,
    "inline_blame": {
      "enabled": false,
    },
  },
  "ui_font_family": ".SystemUIFont",
  "auto_update": false,
  "terminal": {
    "max_scroll_history_lines": 20000,
    "font_family": "Monaspace Neon",
    "copy_on_select": true,
    "font_size": 12.0,
    "button": false,
    "cursor_shape": "bar",
  },
  "telemetry": {
    "diagnostics": false,
    "metrics": false,
  },
  "modeline_lines": 0,
  "base_keymap": "VSCode",
  "edit_predictions": {
    "provider": "copilot",
  },
  "agent": {
    "show_turn_stats": true,
    "profiles": {
      "write": {
        "name": "Write",
        "tools": {
          "copy_path": true,
          "create_directory": true,
          "delete_path": true,
          "diagnostics": true,
          "edit_file": true,
          "fetch": true,
          "list_directory": true,
          "project_notifications": false,
          "move_path": true,
          "now": true,
          "find_path": true,
          "read_file": true,
          "restore_file_from_disk": true,
          "save_file": true,
          "open": true,
          "grep": true,
          "spawn_agent": true,
          "terminal": true,
          "thinking": true,
          "update_plan": true,
          "search_web": true,
        },
        "enable_all_context_servers": true,
        "context_servers": {
          "nixos": {
            "tools": {
              "nix": true,
            },
          },
        },
      },
      "ask": {
        "name": "Ask",
        "tools": {
          "diagnostics": true,
          "fetch": true,
          "list_directory": true,
          "project_notifications": false,
          "now": true,
          "find_path": true,
          "read_file": true,
          "open": true,
          "grep": true,
          "spawn_agent": true,
          "thinking": true,
          "update_plan": true,
          "search_web": true,
        },
        "enable_all_context_servers": false,
        "context_servers": {
          "nixos": {
            "tools": {
              "nix_versions": true,
              "nix": true,
            },
          },
        },
      },
    },
    "tool_permissions": {
      "tools": {
        "mcp:nixos:nix": {
          "default": "allow",
        },
        "terminal": {
          "always_allow": [
            {
              "pattern": "^cargo\\s+check(\\s|$)",
            },
          ],
        },
        "fetch": {
          "always_allow": [
            {
              "pattern": "^https?://raw\\.githubusercontent\\.com",
            },
            {
              "pattern": "^https?://github\\.com",
            },
            {
              "pattern": "^https?://crates\\.io",
            },
          ],
        },
      },
    },
    "inline_assistant_model": {
      "provider": "copilot_chat",
      "model": "gpt-5-mini",
      "enable_thinking": false,
    },
    "single_file_review": true,
    "favorite_models": [
      {
        "provider": "copilot_chat",
        "model": "gpt-5-mini",
        "enable_thinking": true,
        "effort": "high"
      },
      {
        "provider": "copilot_chat",
        "model": "gemini-3.1-pro-preview",
        "enable_thinking": true,
        "effort": "high"
      },
      {
        "provider": "copilot_chat",
        "model": "gpt-5.4-mini",
        "enable_thinking": false,
        "effort": "medium"
      }
    ],
    "default_profile": "ask",
    "default_width": 320.0,
    "default_model": {
      "effort": "medium",
      "enable_thinking": false,
      "provider": "copilot_chat",
      "model": "gpt-5.4-mini",
    },
    "dock": "left",
    "use_modifier_to_send": false,
    "enable_feedback": false,
    "enabled": true,
    "button": true,
    "model_parameters": [],
  },
  "context_servers": {
    "nixos": {
      "enabled": true,
      "remote": false,
      "command": "nix",
      "args": ["run", "github:utensils/mcp-nixos", "--"],
      "env": {},
    },
  },
  "preview_tabs": {
    "enabled": false,
  },
  "show_signature_help_after_edits": false,
  "auto_signature_help": false,
  "multi_cursor_modifier": "cmd_or_ctrl",
  "autosave": "on_focus_change",
  "ui_font_size": 13.0,
  "buffer_font_size": 10.0,
  "icon_theme": "Material Icon Theme",
  "theme": "Catppuccin Mocha",
  // Fix comment colors
  "theme_overrides": {
    "Catppuccin Mocha": {
      // Color reference: https://catppuccin.com/palette/
      "syntax": {
        "constant.comment.todo": {
          "color": "#f5c2e7", // Catppuccin Mocha Pink
          "font_style": "italic",
        },
        "string.comment.info": {
          "color": "#89dceb", // Catppuccin Mocha Sky
          "font_style": "italic",
        },
        "keyword.comment.warn": {
          "color": "#f9e2af", // Catppuccin Mocha Yellow
          "font_weight": 700,
          "font_style": "italic",
        },
        "property.comment.error": {
          "color": "#f38ba8", // Catppuccin Mocha Red
          "font_weight": 900,
          "font_style": "italic",
        },
      },
    },
  },
  "experimental.theme_overrides": {
    // Mocha base color with transparency
    "background": "#1e1e2e80",
    "editor.background": "#1e1e2e80",
    // "title_bar.background": "#1e1e2e99",
    "tab_bar.background": "#1e1e2e99",
    "toolbar.background": "#1e1e2e99",
    // "status_bar.background": "#1e1e2e99",
    // "editor.gutter.background": "#1e1e2e99",
    // "panel.background": "#1e1e2e20",
    "background.appearance": "transparent",
  },
  "buffer_font_features": {
    "calt": true, // Texture healing
    "liga": true, // Dynamic spacing for certain repeating character patterns like ///
    "ss01": true,
    "ss02": true,
    "ss03": true,
    "ss04": true,
    "ss05": true,
    "ss06": true,
    "ss07": true,
    "ss08": true,
    "ss09": true,
    "ss10": true,
  },
}
