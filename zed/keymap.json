// Zed keymap
//
// For information on binding keys, see the Zed
// documentation: https://zed.dev/docs/key-bindings
//
// To see the default key bindings run `zed: open default keymap`
// from the command palette.
[
  {
    "context": "Workspace",
    "bindings": {
      "ctrl-shift-tab": "pane::ActivatePreviousItem",
      "ctrl-tab": "pane::ActivateNextItem",
    },
  },
  {
    "context": "Workspace",
    "bindings": {
      "ctrl-w": "workspace::CloseWindow",
    },
  },
  {
    "context": "ProjectPanel || GitPanel || OutlinePanel",
    "bindings": {
      "ctrl-w": null,
    },
  },
  {
    "context": "Workspace",
    "bindings": {
      "ctrl-alt-b": "outline_panel::ToggleFocus",
    },
  },
  {
    "context": "Workspace",
    "bindings": {
      "ctrl-shift-b": "workspace::ToggleRightDock",
    },
  },
  {
    "context": "!ContextEditor > (Editor && mode == full)",
    "bindings": {
      "ctrl-alt-i": "assistant::InlineAssist",
    },
  },
  {
    "context": "!ContextEditor > (Editor && mode == full)",
    "bindings": {
      "ctrl-enter": "editor::NewlineBelow",
    },
  },
  {
    "context": "Editor",
    "bindings": {
      "ctrl-enter": "editor::NewlineBelow",
    },
  },
  {
    "context": "(Editor && mode == auto_height)",
    "bindings": {
      "ctrl-shift-enter": "editor::NewlineAbove",
    },
  },
  {
    "context": "Editor",
    "bindings": {
      "ctrl-shift-enter": "editor::NewlineAbove",
    },
  },
  {
    "context": "Editor",
    "bindings": {
      "alt-right": [
        "editor::MoveToEndOfLine",
        {
          "stop_at_soft_wraps": true,
        },
      ],
    },
  },
  {
    "context": "Editor",
    "bindings": {
      "alt-left": [
        "editor::MoveToBeginningOfLine",
        {
          "stop_at_soft_wraps": true,
          "stop_at_indent": true,
        },
      ],
    },
  },
  {
    "context": "(Editor && edit_prediction)",
    "bindings": {
      "alt-l": null,
    },
  },
  {
    "context": "(Editor && (edit_prediction && (showing_completions || in_leading_whitespace)))",
    "bindings": {
      "alt-l": null,
    },
  },
  {
    "context": "(Editor && edit_prediction)",
    "bindings": {
      "alt-tab": null,
    },
  },
  {
    "context": "(Editor && (edit_prediction && (showing_completions || in_leading_whitespace)))",
    "bindings": {
      "tab": "editor::AcceptEditPrediction",
    },
  },
  {
    "context": "(Editor && (edit_prediction && (showing_completions || in_leading_whitespace)))",
    "bindings": {
      "alt-tab": null,
    },
  },
  {
    "context": "(Editor && edit_prediction)",
    "bindings": {
      "ctrl-down": "editor::AcceptNextLineEditPrediction",
    },
  },
  {
    "context": "(Editor && (edit_prediction && (showing_completions || in_leading_whitespace)))",
    "bindings": {
      "ctrl-down": "editor::AcceptNextLineEditPrediction",
    },
  },
  {
    "context": "Editor",
    "bindings": {
      "ctrl-r": "editor::Rename",
    },
  },
  {
    "context": "ProjectPanel",
    "bindings": {
      "ctrl-r": "project_panel::Rename",
    },
  },
  {
    "context": "Editor",
    "bindings": {
      "ctrl-alt-down": "editor::DuplicateLineDown",
    },
  },
  {
    "context": "Editor",
    "bindings": {
      "ctrl-alt-up": "editor::DuplicateLineUp",
    },
  },
  {
    "context": "Pane",
    "bindings": {
      "ctrl-alt-_": "workspace::DecreaseOpenDocksSize",
    },
  },
  {
    "context": "Workspace",
    "bindings": {
      "ctrl-alt--": null,
    },
  },
  {
    "context": "Pane",
    "bindings": {
      "ctrl-alt-=": "pane::GoForward",
    },
  },
  {
    "bindings": {
      "alt-d": "editor::ToggleDiagnostics",
    },
  },
  {
    "context": "(GitPanel > Editor)",
    "bindings": {
      "ctrl-space": "git::StageAll",
    },
  },
  {
    "context": "(GitPanel > Editor)",
    "bindings": {
      "ctrl-shift-space": "git::UnstageAll",
    },
  },
  {
    "context": "(GitPanel > Editor)",
    "bindings": {
      "ctrl-enter": "git::Commit",
    },
  },
  {
    "context": "(GitPanel > Editor)",
    "bindings": {
      "ctrl-shift-enter": "git::Amend",
    },
  },
  {
    "context": "AgentPanel",
    "bindings": {
      "ctrl-alt-n": "agent::RejectOnce",
    },
  },
  {
    "context": "AgentPanel",
    "unbind": {
      "ctrl-alt-z": "agent::RejectOnce",
    },
  },
  {
    "context": "AgentDiff",
    "bindings": {
      "ctrl-alt-n": "agent::Reject",
    },
  },
  {
    "context": "AgentDiff",
    "unbind": {
      "ctrl-alt-z": "agent::Reject",
    },
  },
  {
    "context": "Editor && editor_agent_diff",
    "bindings": {
      "ctrl-alt-n": "agent::Reject",
    },
  },
  {
    "context": "Editor && editor_agent_diff",
    "unbind": {
      "ctrl-alt-z": "agent::Reject",
    },
  },
  {
    "context": "Editor && editor_agent_diff",
    "bindings": {
      "alt-shift-n": "agent::RejectAll",
    },
  },
  {
    "context": "Editor && editor_agent_diff",
    "unbind": {
      "alt-shift-z": "agent::RejectAll",
    },
  },
  {
    "context": "AgentDiff",
    "bindings": {
      "alt-shift-n": "agent::RejectAll",
    },
  },
  {
    "context": "AgentDiff",
    "unbind": {
      "alt-shift-z": "agent::RejectAll",
    },
  },
  {
    "context": "AcpThread > Editor",
    "bindings": {
      "alt-shift-n": "agent::RejectAll",
    },
  },
  {
    "context": "AcpThread > Editor",
    "unbind": {
      "alt-shift-z": "agent::RejectAll",
    },
  },
  {
    "context": "AgentPanel",
    "bindings": {
      "alt-/": "agent::ToggleProfileSelector",
    },
  },
  {
    "context": "AgentPanel",
    "unbind": {
      "ctrl-i": "agent::ToggleProfileSelector",
    },
  },
  {
    "context": "AcpThread > Editor",
    "bindings": {
      "alt-/": "agent::ToggleProfileSelector",
    },
  },
  {
    "context": "AcpThread > Editor",
    "unbind": {
      "ctrl-i": "agent::ToggleProfileSelector",
    },
  },
  {
    "bindings": {
      "alt-m": "editor::ToggleMinimap",
    },
  },
  {
    "context": "AgentPanel",
    "bindings": {
      "ctrl-alt-/": "agent::ToggleModelSelector",
    },
  },
  {
    "bindings": {
      "alt-shift-l": "zed::OpenLog",
    },
  },
  {
    "context": "Onboarding",
    "unbind": {
      "alt-shift-l": "onboarding::SignIn",
    },
  },
  {
    "context": "!Terminal",
    "unbind": {
      "ctrl-shift-c": "collab_panel::ToggleFocus",
    },
  },
]
